{
  "expo": {
    "name": "Chehia",
    "slug": "chehia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "chehia",
    "userInterfaceStyle": "light",
    "backgroundColor": "#FAF6EF",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "tn.chehia.app",
      "supportsTablet": false,
      "associatedDomains": ["applinks:chehia.tn", "applinks:go.chehia.tn"],
      "infoPlist": {
        "NSCameraUsageDescription": "Chehia utilise la caméra pour scanner le code QR de votre table. / تستخدم شهية الكاميرا لمسح رمز QR الخاص بطاولتك."
      }
    },
    "android": {
      "package": "tn.chehia.app",
      "adaptiveIcon": {
        "backgroundColor": "#BC4B26",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "chehia.tn", "pathPrefix": "/r" },
            { "scheme": "https", "host": "go.chehia.tn", "pathPrefix": "/r" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#BC4B26",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-localization",
      [
        "expo-camera",
        {
          "cameraPermission": "Chehia utilise la caméra pour scanner le code QR de votre table."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
